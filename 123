            font-size: 0.95rem;
            color: #2ecc71; 
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transform: translateY(10px);
            transition: transform 0.4s ease;
        }

        /* تأثيرات معرض الأعمال المتقدمة */
        .portfolio-card:hover {
            border-color: #2ecc71;
            box-shadow: 0 15px 40px rgba(46, 204, 113, 0.15);
