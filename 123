        }

        /* Hero Section */
        .hero-section {
            position: relative;
            width: 100%;
            min-height: 100vh; 
            background-image: var(--hero-bg-image); 
            background-size: contain; 
            background-position: right center; 
            background-repeat: no-repeat;
            display: flex;
            align-items: center;
            background-color: #111a1e; 
            overflow: hidden;
        }

        /* تظليل متدرج سينمائي للكمبيوتر */
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to right, rgba(17, 26, 30, 1) 35%, rgba(17, 26, 30, 0.5) 70%, rgba(17, 26, 30, 0.2) 100%),
                        linear-gradient(to bottom, rgba(17, 26, 30, 0) 80%, rgba(17, 26, 30, 1) 100%);
            z-index: 1;
        }

        /* جزيئات عائمة */
        .bg-animation {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            display: block;
            background: rgba(46, 204, 113, 0.15);
            border-radius: 50%;
            bottom: -100px;
            animation: floatUp 15s infinite linear;
        }

        .particle:nth-child(1) { left: 10%; width: 40px; height: 40px; animation-duration: 12s; }
        .particle:nth-child(2) { left: 30%; width: 20px; height: 20px; animation-duration: 18s; background: rgba(46, 204, 113, 0.1); }
        .particle:nth-child(3) { left: 50%; width: 50px; height: 50px; animation-duration: 22s; }
        .particle:nth-child(4) { left: 70%; width: 30px; height: 30px; animation-duration: 16s; }
        .particle:nth-child(5) { left: 90%; width: 45px; height: 45px; animation-duration: 20s; }

        @keyframes floatUp {
            0% { transform: translateY(0) scale(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 0.8; }
            100% { transform: translateY(-110vh) scale(1); opacity: 0; }
        }

        .hero-container {
