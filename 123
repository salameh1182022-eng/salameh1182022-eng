            }
            .hero-section::before {
                background: linear-gradient(to bottom, rgba(17, 26, 30, 0.6) 0%, rgba(17, 26, 30, 0.9) 100%);
            }
            .hero-content, .about-image-side, .about-content-side {
                width: 100%;
                display: block;
                padding: 0;
            }
            .hero-content {
                text-align: center;
                padding-top: 60px;
            }
            .hero-desc {
