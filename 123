                gap: 25px;
            }
            .portfolio-card {
                height: 300px;
            }
            .contact-item {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid #2e3f47;
                padding: 15px 0;
            }
            .contact-item:last-child {
                border-bottom: none;
            }
            .hero-title {
                font-size: 2.5rem;
            }
        }
    </style>
